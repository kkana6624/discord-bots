# ==========================================
# Discord AND Role Controller Configuration
# ==========================================

# 1. Discord Bot Token
# Discord Developer Portal (https://discord.com/developers/applications) の "Bot" タブから取得したトークン。
# ※ OCI Vault を利用したセキュア運用の場合は、この行をコメントアウトするか削除してください。
# （Vaultから動的に取得されます）
DISCORD_TOKEN="Your_Discord_Bot_Token_Here"

# 2. Discord Server (Guild) ID
# Botを動作させる対象サーバーのID（サーバーアイコンを右クリックして「サーバーIDをコピー」）
GUILD_ID="123456789012345678"

# 3. AND条件となるロールID
# 以下の2つのロール両方を持っているユーザーが対象となります。（ロールを右クリックして「ロールIDをコピー」）
ROLE_A_ID="111111111111111111"
ROLE_B_ID="222222222222222222"

# 4. 付与/剥奪するターゲットロールID
# 上記2つの条件を満たしたときに自動付与されるロールのID
TARGET_ROLE_C_ID="333333333333333333"
